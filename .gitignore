# === SQLite Database ===
# Ignores the local SQLite database files so you don't accidentally commit your data
*.sqlite3
*.db
*.db-journal
*.db-wal

# === Virtual Environments ===
# Prevents committing your local Python dependencies
.venv/
venv/
env/
ENV/

# === Environment Variables / Secrets ===
# Crucial: Never commit your secrets, tokens, or local settings
.env
.env.*
!.env.example

# === Python Cache & Build Artifacts ===
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# === IDEs and System Files ===
.vscode/
.idea/
.DS_Store
Thumbs.db